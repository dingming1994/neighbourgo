rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile photos ────────────────────────────────────────────────────
    match /profile_photos/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024    // 10 MB
                   && request.resource.contentType.matches("image/.*");
    }

    // ── Task photos ───────────────────────────────────────────────────────
    match /task_photos/{taskId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches("image/.*");
    }

    // ── Chat media ────────────────────────────────────────────────────────
    match /chat_media/{chatId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024    // 20 MB
                   && (request.resource.contentType.matches("image/.*")
                       || request.resource.contentType.matches("video/.*"));
    }

    // ── Verification docs (private — user only) ───────────────────────────
    match /verification_docs/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
